# Environment Variables Configuration for Production Environment
# Do not commit the actual .env file. Copy this file to .env and change values.

# Database settings
POSTGRES_USER=fuelix_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=fuelix_db

# Security settings
# IMPORTANT: Generate a new random secret key (e.g., using `openssl rand -hex 32`)
SECRET_KEY=change-me-to-a-very-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Frontend Variables
API_URL=http://your_domain_or_ip/api/v1
